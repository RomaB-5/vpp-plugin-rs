option version = "1.0.0";

enum test_node_type {
  TEST_NODE_TYPE_X1,
  TEST_NODE_TYPE_X4,
};

/**
 * @brief Enable/disable test node on a given interface
 * @param enable - Zero to disable, non-zero to enable
 * @param sw_if_index - Interface
 */
autoreply autoendian define test_enable_disable
{
  u32 client_index;
  u32 context;
  bool enable;
  u32 sw_if_index;
  vl_api_test_node_type_t node_type;
};

typedef test_type {
  u32 field1;
};

autoreply autoendian define test_type_in_message
{
  u32 client_index;
  u32 context;
  vl_api_test_type_t test_type;
};

typedef test_array_type {
  u16 array[2];
};

autoreply autoendian define test_array
{
  u32 client_index;
  u32 context;
  u32 array1[4];
  vl_api_test_array_type_t array2;
  vl_api_test_node_type_t array3[2];
  f64 array4[2];
};

autoendian define test_response
{
  u32 client_index;
  u32 context;
  u16 value;
};

autoendian define test_response_reply
{
  u32 context;
  i32 retval;
  u16 value;
};

autoendian define test_response_no_retval
{
  u32 client_index;
  u32 context;
  f64 value;
};

autoendian define test_response_no_retval_reply
{
  u32 context;
  f64 value;
};

autoendian define test_dump
{
  u32 client_index;
  u32 context;
};

autoendian define test_details
{
  u32 client_index;
  u32 context;
  u8 value;
};

autoendian autoreply define test_stream_get
{
  u32 client_index;
  u32 context;
};

autoendian define test_stream_details
{
  u32 client_index;
  u32 context;
  u8 value;
};

service {
  rpc test_stream_get returns test_stream_get_reply
    stream test_stream_details;
};
